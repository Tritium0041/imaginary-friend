{
  "name": "时空拍卖行",
  "name_en": "Chronos Auction House",
  "description": "穿梭于各个平行宇宙的古董商在拍卖会上竞拍稀世珍宝，通过收集不同时代的文物、操纵时代倍率和利用功能卡来获取最高胜利点数。",
  "player_count_min": 3,
  "player_count_max": 5,
  "version": "1.0",

  "resources": [
    {
      "id": "money",
      "name": "资金",
      "icon": "💰",
      "scope": "player",
      "initial_value": 20,
      "min_value": 0,
      "max_value": null
    },
    {
      "id": "victory_points",
      "name": "胜利点数",
      "icon": "🏆",
      "scope": "player",
      "initial_value": 0,
      "min_value": 0,
      "max_value": null
    },
    {
      "id": "stability",
      "name": "时空稳定性",
      "icon": "⏳",
      "scope": "global",
      "initial_value": 100,
      "min_value": 0,
      "max_value": 100
    }
  ],

  "categories": [
    {
      "id": "era",
      "name": "时代",
      "values": [
        { "id": "ancient", "name": "古代", "icon": "🟡" },
        { "id": "modern", "name": "近代", "icon": "🔵" },
        { "id": "future", "name": "未来", "icon": "🟣" }
      ],
      "has_multiplier": true,
      "multiplier_range": [0.5, 2.5],
      "initial_multiplier": 1.0
    },
    {
      "id": "rarity",
      "name": "稀有度",
      "values": [
        { "id": "legendary", "name": "传奇", "icon": "★" },
        { "id": "rare", "name": "稀有", "icon": "●" },
        { "id": "common", "name": "常见", "icon": "○" }
      ],
      "has_multiplier": false
    }
  ],

  "object_types": [
    {
      "id": "artifact",
      "name": "文物",
      "properties": [
        { "id": "era", "type": "category_ref", "name": "时代", "category": "era" },
        { "id": "rarity", "type": "category_ref", "name": "稀有度", "category": "rarity" },
        { "id": "base_value", "type": "integer", "name": "基础价值", "min": 0 },
        { "id": "time_cost", "type": "integer", "name": "时空消耗" },
        { "id": "auction_type", "type": "enum", "name": "拍卖类型", "values": ["open", "sealed"] },
        { "id": "keywords", "type": "string_list", "name": "关键词" }
      ],
      "deck_name": "文物牌库"
    },
    {
      "id": "function_card",
      "name": "功能卡",
      "properties": [
        { "id": "effect", "type": "text", "name": "效果" },
        { "id": "category", "type": "enum", "name": "类别", "values": ["disruption", "multiplier", "auction"] },
        { "id": "description", "type": "text", "name": "描述" }
      ],
      "deck_name": "功能卡库"
    },
    {
      "id": "event_card",
      "name": "事件卡",
      "properties": [
        { "id": "effect", "type": "text", "name": "效果" },
        { "id": "category", "type": "enum", "name": "类别", "values": ["disruption", "multiplier", "auction"] },
        { "id": "description", "type": "text", "name": "描述" }
      ],
      "deck_name": "事件卡库",
      "area_name": "事件区",
      "area_size": 2
    }
  ],

  "zones": [
    {
      "id": "auction_pool",
      "name": "拍卖区",
      "object_type": "artifact",
      "auto_refill": {
        "source": "artifact_deck",
        "target_size": "player_count + 1",
        "extra_condition": "stability < 30 → +1"
      }
    },
    {
      "id": "system_warehouse",
      "name": "系统仓库",
      "object_type": "artifact"
    },
    {
      "id": "discard_pile",
      "name": "文物弃牌堆",
      "object_type": "artifact"
    },
    {
      "id": "card_discard_pile",
      "name": "功能卡弃牌堆",
      "object_type": "function_card"
    },
    {
      "id": "event_discard_pile",
      "name": "事件弃牌堆",
      "object_type": "event_card"
    }
  ],

  "phases": [
    {
      "id": "setup",
      "name": "初始化",
      "auto": true
    },
    {
      "id": "excavation",
      "name": "挖掘阶段",
      "actions": [
        "补充拍卖区至 player_count + 1 件文物",
        "每3回合每位玩家抽1张功能卡"
      ]
    },
    {
      "id": "auction",
      "name": "拍卖阶段",
      "actions": [
        "对拍卖区每件文物进行拍卖（公开或密封）"
      ],
      "player_interaction": "sequential_polling"
    },
    {
      "id": "trading",
      "name": "交易阶段",
      "actions": [
        "玩家间自由交易",
        "可出售文物给系统"
      ],
      "player_interaction": "sequential_polling"
    },
    {
      "id": "buyback",
      "name": "回购拍卖阶段",
      "trigger_condition": "偶数回合 或 system_warehouse.count >= 6",
      "actions": [
        "系统仓库中的文物进行公开拍卖"
      ],
      "player_interaction": "sequential_polling"
    },
    {
      "id": "event",
      "name": "事件阶段",
      "actions": [
        "翻开事件区事件卡",
        "对事件区事件投票",
        "执行得票最高的事件"
      ],
      "player_interaction": "sequential_polling"
    },
    {
      "id": "vote",
      "name": "投票阶段",
      "actions": [
        "起始玩家发起倍率调整提议",
        "所有玩家投票（使用投票标记）"
      ],
      "player_interaction": "sequential_polling"
    },
    {
      "id": "stabilize",
      "name": "稳定阶段",
      "actions": [
        "玩家可弃卡或捐资金修复稳定性"
      ],
      "player_interaction": "sequential_polling"
    },
    {
      "id": "game_over",
      "name": "游戏结束",
      "auto": true
    }
  ],

  "phase_order": ["excavation", "auction", "trading", "buyback", "event", "vote", "stabilize"],

  "victory": {
    "formula": "sum(artifact.base_value * era_multiplier[artifact.era]) + (money / 10) + set_bonus",
    "end_conditions": [
      "文物牌库为空且拍卖阶段结束",
      "时空稳定性降为0"
    ],
    "set_bonuses": [
      { "name": "时空博学家", "condition": "拥有3个不同时代各至少1件文物", "bonus": 5 },
      { "name": "时代专精者", "condition": "同一时代3件文物", "bonus": 5 },
      { "name": "关键词收集者", "condition": "同一关键词3件文物", "bonus": 5 }
    ]
  },

  "special_mechanics": [
    {
      "id": "sealed_auction",
      "name": "密封竞标",
      "description": "所有玩家同时秘密出价，最高出价者获胜。平局时按行动顺序裁定。"
    },
    {
      "id": "open_auction",
      "name": "公开拍卖",
      "description": "依次出价，pass不可重入，最后一位出价者获胜。"
    },
    {
      "id": "stability_system",
      "name": "时空稳定性",
      "description": "每次拍卖成交扣减稳定性（基于time_cost），稳定性为0时游戏提前结束。玩家可在稳定阶段捐资金/弃卡修复。"
    },
    {
      "id": "vote_system",
      "name": "投票机制",
      "description": "每回合起始玩家发起倍率调整提议，所有玩家用投票标记（✅/❌）投票，使用后不可恢复。"
    }
  ],

