    "function_card": [
      { "id": "func_01", "name": "赝品指控", "properties": { "effect": "指定场上或任意玩家持有的一件文物，该文物的基础价值永久-2（最低为0）。", "category": "disruption", "description": "破坏对手的高价值文物" } },
      { "id": "func_02", "name": "快速调包", "properties": { "effect": "将拍卖区中的一张文物与牌堆顶文物交换（新文物立即翻开）。", "category": "disruption", "description": "改变拍卖区的文物" } },
      { "id": "func_03", "name": "拍卖劫持", "properties": { "effect": "取消当前正在进行的拍卖，该文物进入弃牌堆，所有已出价金返还。", "category": "disruption", "description": "强制取消拍卖" } },
      { "id": "func_04", "name": "强制征收", "properties": { "effect": "指定一名玩家，强制与其交换一件文物，交换价格固定为10资金（由你支付给对方）。", "category": "disruption", "description": "强制交易文物" } },
      { "id": "func_05", "name": "文物封存", "properties": { "effect": "指定对手的一张文物，该文物本回合禁止出售、交易，且不计入套装奖励。", "category": "disruption", "description": "暂时冻结文物" } },
      { "id": "func_06", "name": "套装破坏者", "properties": { "effect": "指定一名对手，查看其所有文物，选择其中一张强制其以半价出售给系统（向下取整）。", "category": "disruption", "description": "强制对手出售文物" } },
      { "id": "func_07", "name": "收藏劫掠", "properties": { "effect": "指定一名玩家，从其手中随机抽取一张文物卡（需支付其5资金作为补偿）。", "category": "disruption", "description": "抢夺对手文物" } },
      { "id": "func_08", "name": "时空置换", "properties": { "effect": "选择场上两名玩家（可包括自己），强制他们交换一件文物（双方各自选择要交换出去的文物）。", "category": "disruption", "description": "强制两人交换文物" } },
      { "id": "func_09", "name": "伪造鉴定", "properties": { "effect": "指定任意玩家持有的一件文物，将其时代属性改为你指定的一个时代。", "category": "disruption", "description": "改变文物时代" } },
      { "id": "func_10", "name": "黑市没收", "properties": { "effect": "本回合拍卖阶段结束时使用，选择本回合任意一名竞拍成功的玩家，将其刚获得的文物转移给你（需支付其成交价的80%，向上取整）。", "category": "disruption", "description": "截胡他人拍得的文物" } },

      { "id": "func_11", "name": "倍率冲击", "properties": { "effect": "立即将指定一个时代的倍率上升或下降0.5（仍受×0.5到×2.5限制）。", "category": "multiplier", "description": "直接调整倍率" } },
      { "id": "func_12", "name": "倍率固锁", "properties": { "effect": "在投票阶段前使用，指定一个时代，本回合该时代倍率不可通过投票调整。", "category": "multiplier", "description": "锁定倍率" } },
      { "id": "func_13", "name": "市场操纵", "properties": { "effect": "在投票阶段使用，你可以额外发起一次倍率调整提议（不占用正常提议次数）。", "category": "multiplier", "description": "额外发起提议" } },
      { "id": "func_14", "name": "倍率互换", "properties": { "effect": "立即交换任意两个时代的当前倍率值。", "category": "multiplier", "description": "交换两个时代倍率" } },
      { "id": "func_15", "name": "事件预测", "properties": { "effect": "查看事件牌堆顶3张卡牌，按任意顺序放回。", "category": "multiplier", "description": "预知事件" } },
      { "id": "func_16", "name": "强制平衡", "properties": { "effect": "立即将所有时代倍率重置为×1.0。", "category": "multiplier", "description": "重置所有倍率" } },
      { "id": "func_17", "name": "投票操控", "properties": { "effect": "在投票阶段使用，本回合你的每个投票标记（✅/❌）计为2票。", "category": "multiplier", "description": "双倍投票权" } },

      { "id": "func_18", "name": "密标窥探", "properties": { "effect": "密封竞标中，可以偷看一名玩家的出价筹码。", "category": "auction", "description": "偷看密封出价" } },
      { "id": "func_19", "name": "密标干扰", "properties": { "effect": "密封竞标中，强制指定一名玩家提前亮出其出价（其他玩家随后亮出）。", "category": "auction", "description": "破坏密封竞标" } },
